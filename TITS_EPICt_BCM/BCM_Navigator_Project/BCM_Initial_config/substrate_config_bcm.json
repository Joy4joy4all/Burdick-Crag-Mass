  "pain_indicators": {
    "eddington_exceeded": {
      "description": "Maintenance luminosity exceeds Eddington limit",
      "severity": "CRITICAL",
      "action": "Model failure — SMBH cannot provide required power"
    },
    "alpha_bifurcation": {
      "description": "Memory coefficient exceeds 0.90 stability boundary",
      "severity": "CRITICAL",
      "action": "System divergence — reduce alpha immediately"
    },
    "gate_fail": {
      "description": "R_9to10 below 0.92 threshold",
      "severity": "HIGH",
      "action": "NO-GO — destination cannot support coherent arrival"
    },
    "phase_violation": {
      "description": "PhiRMS exceeds PHI_SAFETY",
      "severity": "HIGH",
      "action": "Crew risk — emergency freeboard vent"
    },
    "mirror_fog": {
      "description": "Δ_OP exceeds 0.08",
      "severity": "MEDIUM",
      "action": "STARGATE condition compromised — D operation needed"
    },
    "brucetron_headroom": {
      "description": "BruceRMS approaching pain threshold",
      "severity": "MEDIUM",
      "action": "Chi freeboard discharge recommended"
    },
    "red_zone": {
      "description": "Lambda in RED corridor (> 0.07)",
      "severity": "HIGH",
      "action": "Exclusion zone — do not transit"
    }
  },

  "hypothesis_templates": {
    "H1_kappa_correct": {
      "description": "κ_BH = 2.0 is the correct global coupling constant",
      "evidence_for": ["chi2_bcm < chi2_nfw", "winner_chi2 == BCM"],
      "evidence_against": ["chi2_bcm > chi2_nfw * 2", "winner_chi2 == NFW"],
      "prior": 0.6
    },
    "H2_tully_fisher": {
      "description": "Maintenance luminosity scales as v_max^4 (Tully-Fisher)",
      "evidence_for": ["L_nu_scaling_exponent > 3.5 and < 4.5"],
      "evidence_against": ["L_nu_scaling_exponent < 3.0 or > 5.0"],
      "prior": 0.5
    },
    "H3_class_boundaries": {
      "description": "Six substrate classes are physically real boundaries",
      "evidence_for": ["classification stable under parameter sweep"],
      "evidence_against": ["reclassification under ±10% sweep"],
      "prior": 0.7
    },
    "H4_boundary_layer": {
      "description": "Jasper Beach boundary operator works at all arrival profiles",
      "evidence_for": ["all profiles STARGATE COMPLETE", "zero crew violations"],
      "evidence_against": ["any profile ABORT", "crew violation detected"],
      "prior": 0.8
    },
    "H5_sub_eddington": {
      "description": "All galaxies maintainable below Eddington luminosity",
      "evidence_for": ["all L_nu_L_edd < 1.0"],
      "evidence_against": ["any L_nu_L_edd >= 1.0"],
      "prior": 0.7
    }
  }
}
