          "notes": "How well the craft sees its own f/2 heartbeat in the 7D mirror."
        },
        "opc": {
          "display_name": "Spatial C-arc (OpC)",
          "keywords": ["OpC", "spatial_arc"],
          "baseline_value": 1.0,
          "unit": "dimensionless [0,1]",
          "frozen": false,
          "pain_threshold": 0.5,
          "pain_direction": "below",
          "notes": "Trailing shadow geometry in 7D. Velocity-dependent reflectivity."
        },
        "delta_op": {
          "display_name": "Operator Divergence (Δ_OP)",
          "keywords": ["opacity_div", "Delta_OP", "delta_op"],
          "baseline_value": 0.0,
          "unit": "dimensionless",
          "frozen": false,
          "pain_threshold": 0.08,
          "pain_direction": "above",
          "notes": "|OpT - OpC|. Mirror fogging. STARGATE condition: < 0.08."
        },
        "r_7d": {
          "display_name": "7D Reflectivity (R_7D)",
          "keywords": ["R_7D", "r_7d", "reflectivity"],
          "baseline_value": 1.0,
          "unit": "dimensionless [0,1]",
          "frozen": false,
          "pain_threshold": 0.92,
          "pain_direction": "below",
          "notes": "Combined mirror polish. STARGATE condition: > 0.92."
        },
        "r_9to10": {
          "display_name": "9D-to-10D Gate (R_9→10)",
          "keywords": ["R_9to10", "gate_pass", "THETA_9TO10"],
          "baseline_value": null,
          "unit": "dimensionless",
          "frozen": false,
          "pain_threshold": 0.92,
          "pain_direction": "below",
          "notes": "10D Key check. Threshold 0.92. Below = NO-GO."
        },
        "coherence": {
          "display_name": "Phase Coherence",
          "keywords": ["Coherence", "coherence", "min_coh"],
          "baseline_value": 1.0,
