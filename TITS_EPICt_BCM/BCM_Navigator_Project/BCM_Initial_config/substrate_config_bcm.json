{
  "config_name": "BCM_SUBSTRATE_MAINTENANCE",
  "version": "v23.0",
  "author": "Stephen Justin Burdick Sr.",
  "entity": "Emerald Entities LLC — GIBUSH Systems",
  "description": "Substrate maintenance cost configuration. Each category maps to a process stage in the substrate chain. Components within each category are the items paying the tax. Keywords link to test JSON output fields. Baselines are frozen constants or theoretical values. Pain thresholds flag when the budget is exceeded.",

  "process_chain": [
    "SMBH Pump → Substrate Field → Torus Edge → Boundary Layer → Dimensional Gate → Crew Envelope → Navigation"
  ],

  "module_categories": {

    "smbh_pump": {
      "name": "SMBH Pump System",
      "description": "The funding source. Neutrino flux from the black hole that pays the substrate maintenance cost. Upstream origin — everything downstream depends on this budget.",
      "mill_analog": "Wood Yard — raw material intake",
      "modules": {
        "kappa_bh": {
          "display_name": "BH Coupling (κ_BH)",
          "keywords": ["kappa", "crag_kappa", "kappa_BH", "BH coupling"],
          "baseline_value": 2.0,
          "unit": "dimensionless",
          "frozen": true,
          "pain_threshold": null,
          "notes": "Frozen after calibration on NGC2841/NGC7331/NGC3521. If this needs per-galaxy tuning, the mechanism fails."
        },
        "j_crag": {
          "display_name": "Crag Mass Injection (J_crag)",
          "keywords": ["J_crag", "nu_fraction", "J_bar_peak", "J_nu_peak", "crag_mass"],
          "baseline_value": null,
          "unit": "field amplitude",
          "frozen": false,
          "pain_threshold": null,
          "notes": "Scales with M_BH. Neutrino source kernel normalized to J_baryon peak."
        },
        "mbh_catalog": {
          "display_name": "BH Mass Catalog",
          "keywords": ["M_bh", "M_bh_solar", "mbh_source", "estimated", "catalog"],
          "baseline_value": null,
          "unit": "M_sun",
          "frozen": false,
          "pain_threshold": null,
          "notes": "Catalog values from Kormendy & Ho 2013. Estimated via M-sigma relation when no catalog entry."
        },
        "l_nu": {
          "display_name": "Maintenance Luminosity (L_ν)",
          "keywords": ["L_nu", "L_nu_erg_s", "L_nu_Lsun", "maintenance_luminosity"],
          "baseline_value": null,
          "unit": "erg/s",
          "frozen": false,
          "pain_threshold_key": "L_nu_L_edd",
          "pain_threshold": 1.0,
          "pain_direction": "above",
          "notes": "Must stay sub-Eddington. L_nu/L_edd > 1.0 = physically impossible = model failure."
        },
        "nu_b": {
          "display_name": "Burdick Constant (ν_b)",
          "keywords": ["nu_b", "burdick_constant"],
          "baseline_value": 2.75e12,
          "unit": "erg s^-1 / (cm/s)^4",
          "frozen": false,
          "pain_threshold_cv": 50.0,
          "notes": "L_nu / v_max^4. Should be approximately constant across Class I galaxies. CV > 50% = investigate."
        }
      }
    },

    "substrate_field": {
      "name": "Substrate Field",
      "description": "The medium being maintained. Sigma is the memory field, lambda is the decay rate (the electric bill). This is the product the pump is funding.",
      "mill_analog": "Chip Processing — the material being transported and refined",
      "modules": {
        "lambda_decay": {
          "display_name": "Decay Rate (λ)",
          "keywords": ["lambda", "lam", "decay_rate", "maintenance_cost"],
          "baseline_value": 0.1,
          "unit": "per timestep",
          "frozen": true,
          "pain_threshold": null,
          "notes": "Universal maintenance cost of space. Frozen at 0.1."
        },
        "alpha_memory": {
          "display_name": "Memory Coefficient (α)",
          "keywords": ["alpha", "memory", "ALPHA"],
          "baseline_value": 0.80,
          "unit": "dimensionless",
          "frozen": true,
          "pain_threshold": 0.90,
          "pain_direction": "above",
          "notes": "Operating window 0.75-0.85. Bifurcation blowup at 0.90."
        },
        "sigma_field": {
          "display_name": "Substrate Memory (σ)",
          "keywords": ["sigma", "rho_max", "sigma_avg", "substrate_excess"],
          "baseline_value": null,
          "unit": "field amplitude",
          "frozen": false,
          "pain_threshold": null,
          "notes": "Core field. Cumulative memory of substrate agitation."
        },
        "u_sub": {
          "display_name": "Substrate Usage (U_sub)",
          "keywords": ["U_sub", "substrate_usage", "decoupling_ratio"],
          "baseline_value": null,
          "unit": "1/ν_b",
          "frozen": false,
          "pain_threshold": null,
          "notes": "Reciprocal of Burdick Constant. Higher = more drag tax per unit velocity."
        },
        "cos_delta_phi": {
          "display_name": "Phase Alignment (cos Δφ)",
          "keywords": ["cos_delta_phi", "phase_sigma", "phase_forcing", "delta_phi"],
          "baseline_value": 1.0,
          "unit": "dimensionless [-1,+1]",
          "frozen": false,
          "pain_threshold": 0.0,
          "pain_direction": "below",
          "notes": "+1 = coupled (funded). 0 = decoupled. -1 = anti-phase (destructive)."
        },
        "layer_coherence": {
          "display_name": "Layer Coherence",
          "keywords": ["layer_coherence", "entangle", "avg_layer_corr"],
          "baseline_value": 1.0,
          "unit": "dimensionless [0,1]",
          "frozen": false,
          "pain_threshold": 0.5,
          "pain_direction": "below",
          "notes": "Inter-layer coupling quality. Below 0.5 = substrate layers decoupled."
        }
      }
    },

    "boundary_layer": {
      "name": "Boundary Layer & Torus Edge",
      "description": "Where the substrate meets the edge. Jasper Beach gravel — energy killed before reflection. This is the impact zone.",
      "mill_analog": "Blow Line — where material hits the wall and the physics of impact matters",
      "modules": {
        "k_boundary": {
          "display_name": "Boundary Damping (K_BOUNDARY)",
          "keywords": ["K_BOUNDARY", "boundary", "gradient_kill"],
          "baseline_value": 150.0,
          "unit": "dimensionless",
          "frozen": true,
          "pain_threshold": null,
          "notes": "Jasper Beach analog. Gradient-proportional dissipation at torus edge."
        },
        "phi_safety": {
          "display_name": "Phase Safety (φ_safety)",
          "keywords": ["PHI_SAFETY", "phi_rms", "PhiRMS", "phase_safety"],
          "baseline_value": 0.10,
          "unit": "dimensionless",
          "frozen": true,
          "pain_threshold": 0.10,
          "pain_direction": "above",
          "notes": "Maximum safe phase deviation. Above this = crew risk."
        },
        "gradient_ratio": {
          "display_name": "Gradient Ratio (inner/outer)",
          "keywords": ["gradient_ratio", "v_excess_inner", "v_excess_outer", "lambda_gradient"],
          "baseline_value": 1.0,
          "unit": "dimensionless",
          "frozen": false,
          "pain_threshold": null,
          "notes": "Ratio > 1 = inner-funded, outer-depleted (Class IV). INF = outer dead. ~1 = uniform (Class I)."
        },
        "snap_back": {
          "display_name": "Snap-Back Torque (τ_snap)",
          "keywords": ["snap_back", "tau_snap", "r_arc", "snap"],
          "baseline_value": 0.0,
          "unit": "torque proxy",
          "frozen": false,
          "pain_threshold": null,
          "notes": "V-vector arc-back at torus edge. High = strong restoring torque = spectroscopic imprint."
        }
      }
    },

